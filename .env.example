# Copy to .env.local for local dev

# Mazra Supabase (Mazra Hospital — own project)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_MAZRA_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only (never expose to browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: read-only role for Mazra Hospital data SELECT (API v1). Falls back to SUPABASE_SERVICE_ROLE_KEY.
# SUPABASE_READ_ONLY_SERVICE_ROLE_KEY=

# Upstash Redis — API v1 rate limits (ENG-120)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: backfill depth when seed scripts return (future)
# MAZRA_SEED_DAYS=90

# Public URL of this Next app (Flutterwave redirect)
# MAZRA_APP_URL=https://your-mazra.vercel.app
# MAZRA_PUBLIC_SITE_URL=https://mazra.dev
# MAZRA_LANDING_ORIGIN=https://mazra.dev

# Flutterwave Standard (server-side) — see docs/PHASE6_SAAS.md
# FLW_SECRET_KEY=
# MAZRA_BILLING_LOGO_URL=https://mazra.dev/favicon.ico
