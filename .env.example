# Copy to .env.local for local dev / seed script

# Mazra control-plane Supabase (sim_config, mazra_clients, usage logs)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_MAZRA_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mazra server (service role — never expose to browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Target DB (Kanta-shaped Supabase) — optional ---
# MAZRA_WRITE_TO_TARGET=1
# TARGET_SUPABASE_URL=https://YOUR_KANTA_PROJECT.supabase.co
# TARGET_SUPABASE_SERVICE_ROLE_KEY=

# Trigger API (Vercel cron / manual):
# MAZRA_SIM_SECRET=long-random-string

# Seeder backfill depth (default 3):
# MAZRA_SEED_DAYS=90

# Limit generation to one facility (matches sim_config.facility_id)
# MAZRA_FACILITY_ID=6eafdd6c-cc3b-47cf-8bf6-44d7254be4b5

# Real-time tick (/api/sim/tick) — hospital wall clock for peaks & QC windows
# MAZRA_SIM_TIMEZONE=Africa/Kampala
# MAZRA_TICK_MINUTES=15

# If hospital_id differs from facility_id in Kanta, set explicitly for scan_events:
# MAZRA_HOSPITAL_ID=

# Vercel Cron: set CRON_SECRET to the same value as MAZRA_SIM_SECRET (Bearer on GET /api/sim/run)

# Optional: backfill length for `npm run seed`
# MAZRA_SEED_DAYS=90
