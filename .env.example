# Copy to .env.local for local dev / seed script

# Same Supabase project as Kanta (Nairobi)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Seeder & Edge Functions (server only — never expose to browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: backfill length for `npm run seed`
# MAZRA_SEED_DAYS=90
