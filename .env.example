# Copy to .env.local for local dev / seed script

# Mazra control-plane Supabase (sim_config, mazra_clients, usage logs)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_MAZRA_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mazra server (service role — never expose to browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Target DB (Kanta-shaped Supabase) — optional ---
# MAZRA_WRITE_TO_TARGET=1
# TARGET_SUPABASE_URL=https://YOUR_KANTA_PROJECT.supabase.co
# TARGET_SUPABASE_SERVICE_ROLE_KEY=

# Trigger API (Vercel cron / manual):
# MAZRA_SIM_SECRET=long-random-string

# Seeder backfill depth (default 3):
# MAZRA_SEED_DAYS=90

# Optional: backfill length for `npm run seed`
# MAZRA_SEED_DAYS=90
